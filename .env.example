# ============================================================================
# Collaborative Intelligence — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values for your environment.
#
#   Local (mock DB):   cp .env.example .env.local  → set USE_MOCK_DB=true
#   Local (real DB):   vercel env pull .env.local   → pulls from Vercel project
#   Staging:           Set in Vercel dashboard (Preview scope)
#   Production:        Set in Vercel dashboard (Production scope)
# ============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# Neon Postgres connection strings (auto-provisioned by Vercel Marketplace)
# For local dev with mock DB, these are not needed.
DATABASE_POSTGRES_PRISMA_URL=postgresql://user:password@host/db?sslmode=require&pgbouncer=true
DATABASE_URL_UNPOOLED=postgresql://user:password@host/db?sslmode=require

# Set to "true" to use in-memory mock database (no Postgres needed)
USE_MOCK_DB=false

# ─── Authentication ──────────────────────────────────────────────────────────
# NextAuth.js configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# ─── Security ────────────────────────────────────────────────────────────────
# AES-256-GCM encryption key for OAuth tokens
ENCRYPTION_KEY=  # Generate with: openssl rand -hex 32

# Vercel Cron job authentication (production only)
CRON_SECRET=  # Generate with: openssl rand -base64 32

# ─── Email ───────────────────────────────────────────────────────────────────
# Resend email provider (optional — emails logged to console if not set)
RESEND_API_KEY=

# ─── Google Ads Integration ──────────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# ─── Meta Ads Integration ───────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=

# ─── TikTok Ads Integration ────────────────────────────────────────────────
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_SECRET=

# ─── App URL ─────────────────────────────────────────────────────────────────
# Public-facing URL (used for OAuth callbacks, share links, etc.)
# Vercel sets this automatically in deployments.
NEXT_PUBLIC_APP_URL=http://localhost:3000
